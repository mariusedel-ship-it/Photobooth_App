{
  "name": "PhotoFrame",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name des Frames"
    },
    "category": {
      "type": "string",
      "enum": [
        "event",
        "wedding",
        "brand",
        "fun",
        "minimal"
      ],
      "description": "Kategorie des Frames"
    },
    "overlay_url": {
      "type": "string",
      "description": "URL zum Overlay-Bild (PNG mit Transparenz)"
    },
    "preview_url": {
      "type": "string",
      "description": "Vorschaubild des Frames"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "category"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "write": {
      "created_by": "{{user.email}}"
    }
  }
}